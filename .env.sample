LLM_API_KEY="sk-xxx"
LLM_BASE_URL="https://api.deepseek.com"
LLM_MODEL="deepseek-chat"
# LLM_VERIFY_SSL=true               # Set to false for self-hosted LLMs with self-signed certs
# LLM_TIMEOUT=30.0

# ---------- Embedding (for RAG knowledge base / semantic search) ----------
# Requires an OpenAI-compatible /embeddings endpoint.
# Many chat APIs (e.g. DeepSeek, Claude) do NOT provide embeddings.
# Configure a separate embedding provider here.
#
# Option A: Use a corporate LLM gateway
# EMBEDDING_API_KEY="llmgw-sk-xxx"
# EMBEDDING_BASE_URL="https://llm-gateway.example.com/v1"
# EMBEDDING_MODEL="zoom_qwen3_embed"
#
# Option B: Use Alibaba DashScope (good for Chinese/bilingual)
# EMBEDDING_API_KEY="sk-xxx"
# EMBEDDING_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# EMBEDDING_MODEL="text-embedding-v4"
#
# Option C: Use OpenAI directly
# EMBEDDING_API_KEY="sk-xxx"
# EMBEDDING_BASE_URL="https://api.openai.com/v1"
# EMBEDDING_MODEL="text-embedding-3-small"
#
# Option D: Use local Ollama
# EMBEDDING_API_KEY="ollama"
# EMBEDDING_BASE_URL="http://localhost:11434/v1"
# EMBEDDING_MODEL="nomic-embed-text"
#
# If EMBEDDING_* are empty, falls back to LLM_* settings.
EMBEDDING_API_KEY=""
EMBEDDING_BASE_URL=""
EMBEDDING_MODEL=""
# LLM_EMBEDDING_MODEL="text-embedding-3-small"   # fallback when EMBEDDING_MODEL not set

# ---------- PostgreSQL (for pgvector RAG demo) ----------
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=rag_db
# DB_USER=postgres
# DB_PASS=postgres
# Or use DATABASE_URL (PostgreSQL enables pgvector; SQLite disables RAG vector search)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_db

# ---------- RAG / Vector Store ----------
# VECTOR_STORE=auto   # "auto" (pgvector if PostgreSQL, disabled if SQLite),
#                     # "pgvector", "chromadb", "disabled"
# CHROMA_PERSIST_DIR="data/chroma"   # only used when VECTOR_STORE=chromadb
# RAG_CHUNK_SIZE=512
# RAG_CHUNK_OVERLAP=50
# RAG_SIMILARITY_TOP_K=3

# PlantUML Configuration (for article mindmap rendering)
# PLANTUML_SERVER_URL="http://www.plantuml.com/plantuml"
# PLANTUML_JAR_PATH="/path/to/plantuml.jar"
# PLANTUML_OUTPUT_DIR="static/mindmaps"

# Secretary Agent Logging
# LOG_LEVEL_SECRETARY="INFO"
# TRACE_DETAILED=false
# LOG_FORMAT="text"

# Translation Agent (optional; defaults shown)
# TRANSLATION_MAX_FILE_SIZE_BYTES=10485760
# TRANSLATION_MAX_SOURCE_LENGTH=12000
