# ============================================================================
# Lazy Rabbit Agent — Production Environment Variables
# Copy to .env.production and fill in your values
# ============================================================================

# ---------- Server ----------
DOMAIN=your-domain.com
HTTP_PORT=80
HTTPS_PORT=443

# ---------- Database ----------
DATABASE_URL=postgresql://lra:your-db-password@postgres:5432/lazy_rabbit
DB_USER=lra
DB_PASSWORD=your-db-password
DB_NAME=lazy_rabbit

# ---------- Redis ----------
REDIS_PASSWORD=your-redis-password
REDIS_URL=redis://:your-redis-password@redis:6379/0

# ---------- Security ----------
SECRET_KEY=your-very-long-random-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------- LLM ----------
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-openai-api-key
LLM_MODEL=gpt-4o-mini
LLM_STREAM=true

# ---------- RAG / AI Coach ----------
CHROMA_PERSIST_DIR=/app/data/chroma
LLM_EMBEDDING_MODEL=text-embedding-3-small

# ---------- Celery (optional) ----------
CELERY_BROKER_URL=redis://:your-redis-password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:your-redis-password@redis:6379/0

# ---------- Debug ----------
DEBUG_FLAG=false
